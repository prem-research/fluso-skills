{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/prem-research/fluso-skills/main/schemas/marketplace.schema.json",
  "title": "Fluso Skill Marketplace catalog (V1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skills"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "version",
        "publisher",
        "summary",
        "description",
        "categories",
        "tags",
        "entrypoint",
        "files",
        "footprint",
        "dependencies",
        "safety"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/label"
          }
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "entrypoint": {
          "const": "SKILL.md"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "contains": {
            "const": "SKILL.md"
          },
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+(/[A-Za-z0-9._-]+)*$"
          }
        },
        "footprint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_size_bytes",
            "estimated_installed_size_bytes",
            "estimated_runtime_cache_bytes"
          ],
          "properties": {
            "source_size_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "estimated_installed_size_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "estimated_runtime_cache_bytes": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tier", "recipes", "system_capabilities"],
          "properties": {
            "tier": {
              "type": "string",
              "minLength": 1
            },
            "recipes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/recipe"
              }
            },
            "system_capabilities": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "safety": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "has_helper_scripts",
            "runs_install_script",
            "network_at_runtime"
          ],
          "properties": {
            "has_helper_scripts": {
              "type": "boolean"
            },
            "runs_install_script": {
              "type": "boolean"
            },
            "network_at_runtime": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "project", "package", "version"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "label": {
      "description": "Controlled label set. Keep in sync with README.md (Labels section) and scripts/validate_skills.py (TAXONOMY).",
      "enum": [
        "Marketing",
        "Sales",
        "Legal",
        "Operations",
        "Engineering",
        "Finance",
        "Research",
        "Content",
        "Support",
        "Travel"
      ]
    }
  }
}
